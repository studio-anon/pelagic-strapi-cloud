{
  "kind": "collectionType",
  "collectionName": "journal_articles",
  "info": {
    "singularName": "journal-article",
    "pluralName": "journal-articles",
    "displayName": "Journal Article",
    "description": "Journal article content for listing and detail pages"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "fullIntroduction": { "type": "richtext" },
    "listingIntroduction": { "type": "text" },
    "listingThumbnailDesktop": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "listingThumbnailMobile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "heroImageDesktop": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "heroImageMobile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "publishDate": { "type": "date" },
    "readingTimeMinutes": {
      "type": "integer",
      "min": 1
    },
    "isExternal": { "type": "boolean", "default": false },
    "externalUrl": { "type": "string" },
    "contentBlocks": {
      "type": "dynamiczone",
      "components": [
        "journal.breakout-text",
        "journal.full-width-image",
        "journal.two-images",
        "journal.single-column",
        "journal.two-column",
        "journal.text-image-pair-left",
        "journal.text-image-pair-right",
        "journal.video-embed"
      ]
    }
  }
}
